# Database Configuration
# e.g. postgres://reports_user:supersecret@127.0.0.1:5432/reports_db
DATABASE_URL=
# Set to "true" when your Postgres host requires SSL (e.g., managed cloud providers)
DATABASE_SSL=

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
NEXT_PUBLIC_APP_URL=
TELEGRAM_MINI_APP_URL=

# Web Dashboard (browser) — Telegram OAuth 2.0 / OpenID Connect login
# From @BotFather -> Bot Settings -> Web Login. client_id is the bot's numeric id
# (defaults to the TELEGRAM_BOT_TOKEN prefix if left blank).
TELEGRAM_OAUTH_CLIENT_ID=
TELEGRAM_OAUTH_CLIENT_SECRET=
# The OAuth redirect_uri is built as <NEXT_PUBLIC_APP_URL>/api/dashboard/auth/callback,
# so NEXT_PUBLIC_APP_URL must match a Redirect URI registered in BotFather's Web Login,
# and NEXT_PUBLIC_APP_URL's origin must be listed as a Trusted origin.
# Secret used to sign the dashboard session cookie. Generate a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
DASHBOARD_SESSION_SECRET=

# Google Sheets Integration
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Application Configuration
NODE_ENV=
PORT=

# Local browser debugging (development only)
# Set to "true" to allow opening the app outside Telegram in a browser.
NEXT_PUBLIC_BROWSER_DEBUG_AUTH=

# Admin Configuration (comma-separated list, e.g. 12345,67890)
ADMIN_TELEGRAM_IDS=
NEXT_PUBLIC_ADMIN_TELEGRAM_IDS=
